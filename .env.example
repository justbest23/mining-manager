# ─── RainbowMiner ──────────────────────────────────────────────────────────────
# Absolute path to the rainbowminer directory (setup.sh sets this automatically)
RAINBOWMINER_DIR=./rainbowminer

# RainbowMiner's local REST API port
RAINBOWMINER_API_PORT=4000

# Worker name shown in pool dashboards
WORKER_NAME=trog-4080

# ─── MiningPoolHub ─────────────────────────────────────────────────────────────
# Create account at miningpoolhub.com
# Set your payout coin to LTC in their dashboard → Account → Edit Account → Auto Exchange
MPH_USERNAME=your_mph_username
MPH_API_KEY=your_mph_api_key

# Your Luno LTC deposit address (MiningPoolHub pays here)
MPH_LTC_ADDRESS=your_luno_ltc_deposit_address

# ─── Zpool ─────────────────────────────────────────────────────────────────────
# No registration needed — just your LTC address
ZPOOL_LTC_ADDRESS=your_luno_ltc_deposit_address

# ─── GPU Overclock Profile (RTX 4080, ~153W actual draw) ───────────────────────
# Applied via nvidia-smi when mining starts, reset when mining stops
GPU_CORE_CLOCK_LOCK=2205   # MHz — locked core clock
GPU_POWER_LIMIT_W=350      # Watts — actual draw will be ~153W at locked clocks

# ─── GPU Idle Detection ────────────────────────────────────────────────────────
CHECK_INTERVAL=30          # seconds between GPU state polls
GPU_UTIL_THRESHOLD=15      # % utilisation above which GPU is considered "in use"
IDLE_GRACE_PERIOD=60       # seconds idle before mining starts
BUSY_GRACE_PERIOD=15       # seconds busy before mining stops

# Comma-separated substrings — CUDA processes whose names contain any of these
# are ignored when deciding GPU state. Use this for always-resident background
# processes that you're happy to mine alongside (e.g. Frigate AI detection).
# Encoder/decoder sessions (Plex/Jellyfin transcoding) are NEVER ignored.
# Example: EXCLUDED_PROCESS_PATTERNS=frigate,/app/.venv/bin/python3
EXCLUDED_PROCESS_PATTERNS=frigate,/app/.venv/bin/python3

# ─── Electricity ───────────────────────────────────────────────────────────────
# Tshwane Block 4 prepaid rate — update 1 July each year
ELECTRICITY_RATE_ZAR=4.09
USD_ZAR_RATE=16.52

# ─── Discord ───────────────────────────────────────────────────────────────────
# Channel → Edit → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your/webhook

# Twice-daily report times (24h HH:MM, comma-separated)
REPORT_TIMES=08:00,20:00

# Daily profitability check time
PROFITABILITY_CHECK_TIME=06:00

# ─── Home Assistant ────────────────────────────────────────────────────────────
HA_URL=https://homeass.trog.co.za
HA_TOKEN=your_long_lived_token_here
HA_UPDATE_INTERVAL=60      # seconds between HA sensor pushes

# ─── Jellyfin (optional — enriches stop-reason labels) ────────────────────────
JELLYFIN_URL=http://192.168.0.203:8096
JELLYFIN_API_KEY=
