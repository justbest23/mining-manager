# ─── NiceHash ──────────────────────────────────────────────────────────────────
# Your Bitcoin wallet address (where NiceHash pays out)
NICEHASH_BTC_ADDRESS=your_btc_address_here

# Worker name shown in NiceHash dashboard
NICEHASH_WORKER=trog-4080

# NiceHash stratum region: eu, usa, hk, jp, in, br  (eu is closest for ZA)
NICEHASH_REGION=eu

# ─── lolMiner ──────────────────────────────────────────────────────────────────
# Full path to lolMiner binary
LOLMINER_PATH=/opt/lolMiner/lolMiner

# Local API port for lolMiner stats
LOLMINER_API_PORT=42000

# GPU overclock profile (Kryptex-verified, RTX 4080, ~153W actual draw)
GPU_CORE_CLOCK=2205
GPU_MEM_CLOCK=810
GPU_POWER_LIMIT=350

# ─── GPU Idle Detection ────────────────────────────────────────────────────────
# How often to check GPU state (seconds)
CHECK_INTERVAL=30

# GPU utilisation % above which we consider it "in use" (besides encoder/compute checks)
GPU_UTIL_THRESHOLD=15

# Seconds GPU must be idle before starting to mine (avoids thrashing)
IDLE_GRACE_PERIOD=60

# Seconds after GPU becomes busy before we stop mining (avoids stopping on brief spikes)
BUSY_GRACE_PERIOD=15

# ─── Electricity ───────────────────────────────────────────────────────────────
# Tshwane Block 4 prepaid rate (R/kWh) — update when tariffs change
ELECTRICITY_RATE_ZAR=4.09

# USD/ZAR exchange rate — update periodically or pull from HA currency sensor
USD_ZAR_RATE=16.52

# ─── Discord ───────────────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your/webhook

# Times for twice-daily status report (24h format, comma-separated)
REPORT_TIMES=08:00,20:00

# Time for daily profitability check
PROFITABILITY_CHECK_TIME=06:00

# ─── Home Assistant ────────────────────────────────────────────────────────────
HA_URL=https://homeass.trog.co.za
HA_TOKEN=your_long_lived_token_here

# How often to push sensor updates to HA while mining (seconds)
HA_UPDATE_INTERVAL=60

# ─── Jellyfin (optional — used for richer stop-reason reporting only) ──────────
# Leave blank to skip Jellyfin API checks (GPU process detection still works)
JELLYFIN_URL=http://192.168.0.203:8096
JELLYFIN_API_KEY=
